              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Blocks.*"
            },
            "properties": [
              {
                "id": "unit",
                "value": "none"
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "custom.drawStyle",
                "value": "bars"
              },
              {
                "id": "custom.fillOpacity",
                "value": 30
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
